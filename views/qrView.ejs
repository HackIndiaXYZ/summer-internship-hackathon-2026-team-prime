<link rel="stylesheet" href="/css/style.css"> <button id="theme-btn" class="theme-toggle-btn"></button>


<div class="container" style="text-align:center;">
  <h2>Scan QR to View Patient History</h2>

  <img src="<%= qr %>" width="250" style="margin-top:30px;" />
  
  <p style="margin-top:15px; font-size:14px;">
    Scan this QR with your phone to open the patient's history page
  </p>
</div>
<script>
 
const btn = document.getElementById("theme-btn");

function updateButtonText() {
  btn.textContent = document.body.classList.contains('dark-mode') ? '🌙' : '☀️';
}

btn.addEventListener("click", () => {
  document.body.classList.toggle("dark-mode");
  localStorage.setItem('theme', document.body.classList.contains('dark-mode') ? 'dark' : 'light');
  updateButtonText();
});

// Load saved theme on page load
if(localStorage.getItem('theme') === 'dark'){
  document.body.classList.add('dark-mode');
}
updateButtonText();
</script>