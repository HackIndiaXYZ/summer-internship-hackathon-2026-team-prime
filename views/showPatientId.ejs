<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Your Patient ID</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #e6f2ff; /* Light blue background */
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      color: #333;
    }

    .container {
      background: #ffffff; /* White card */
      padding: 50px 60px;
      border-radius: 15px;
      text-align: center;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
      max-width: 500px;
      width: 90%;
    }

    h2 {
      font-size: 2rem;
      margin-bottom: 20px;
      color: #004080; /* Dark blue heading */
    }

    h1 {
      font-size: 3rem;
      margin-bottom: 30px;
      color: #0073e6; /* Blue Patient ID */
      letter-spacing: 2px;
      word-break: break-word;
    }

    a {
      display: inline-block;
      padding: 12px 25px;
      background-color: #0073e6; /* Blue button */
      color: #fff;
      font-weight: bold;
      text-decoration: none;
      border-radius: 8px;
      transition: all 0.3s ease;
    }

    a:hover {
      background-color: #005bb5; /* Darker blue on hover */
      transform: scale(1.05);
    }
  </style>
</head>
<body>
  <div class="container">
    <h2>Registration Successful!</h2>
    <p>Your unique Patient ID is:</p>
    <h1><%= patientId %></h1>
    <a href="/dashboard">Back to Dashboard</a>
  </div>
</body>
</html>